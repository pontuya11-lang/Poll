<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>ถอดแบบและประมาณราคางานโครงสร้าง</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Sarabun:ital,wght@0,300;0,400;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;600&display=swap');

:root {
  --bg:       #0b0f18;
  --surf:     #111827;
  --surf2:    #1a2235;
  --surf3:    #1f2d42;
  --border:   #243047;
  --border2:  #2e3d56;
  --gold:     #f0b429;
  --gold-dim: #7a5c14;
  --blue:     #3d8ef8;
  --green:    #3dba7c;
  --red:      #e05252;
  --orange:   #f97316;
  --text:     #d8e6f5;
  --sub:      #7a93b0;
  --mono:     'IBM Plex Mono', monospace;
  --sans:     'Sarabun', sans-serif;
  --radius:   6px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { background: var(--bg); color: var(--text); font-family: var(--sans); font-size: 14px; }

/* ── APP SHELL ── */
.app { display: flex; height: 100vh; overflow: hidden; }

/* ── SIDEBAR ── */
.sidebar {
  width: 230px; flex-shrink: 0;
  background: var(--surf);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  overflow-y: auto; overflow-x: hidden;
}
.sb-logo {
  padding: 16px 16px 12px;
  border-bottom: 1px solid var(--border);
}
.sb-logo .title { font-size: 13px; font-weight: 700; color: var(--gold); letter-spacing: .05em; line-height: 1.5; }
.sb-logo .sub   { font-size: 10px; color: var(--sub); margin-top: 3px; }

.nav-block { padding: 8px 0 4px; }
.nav-cat {
  padding: 6px 16px 3px;
  font-size: 9px; font-weight: 700; color: var(--sub);
  letter-spacing: .12em; text-transform: uppercase;
}
.nav-item {
  display: flex; align-items: center; gap: 9px;
  padding: 7px 16px; cursor: pointer;
  border-left: 3px solid transparent;
  color: var(--sub); font-size: 12.5px;
  transition: background .12s, color .12s, border-color .12s;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.nav-item:hover  { background: var(--surf2); color: var(--text); }
.nav-item.active {
  background: var(--surf2);
  border-left-color: var(--gold);
  color: var(--gold); font-weight: 600;
}
.nav-item .ico { font-size: 13px; width: 18px; text-align: center; flex-shrink: 0; }
.nav-subtotal {
  margin-left: auto; font-family: var(--mono);
  font-size: 9px; color: var(--sub); flex-shrink: 0;
}
.nav-item.active .nav-subtotal { color: var(--gold-dim); }

.sb-footer { margin-top: auto; padding: 12px; border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: 6px; }

/* ── BUTTONS ── */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  padding: 7px 13px; border: none; border-radius: var(--radius);
  cursor: pointer; font-family: var(--sans); font-size: 12px; font-weight: 600;
  transition: opacity .15s, transform .1s; letter-spacing: .03em;
}
.btn:active { transform: scale(.97); }
.btn-gold   { background: var(--gold); color: #0b0f18; }
.btn-gold:hover { background: #f7c94b; }
.btn-blue   { background: var(--blue); color: #fff; }
.btn-blue:hover { opacity: .85; }
.btn-green  { background: var(--green); color: #fff; }
.btn-green:hover { opacity: .85; }
.btn-ghost  { background: var(--surf2); border: 1px solid var(--border2); color: var(--text); }
.btn-ghost:hover { background: var(--surf3); }
.btn-danger { background: #3a1010; border: 1px solid var(--red); color: var(--red); }
.btn-danger:hover { background: #4a1515; }
.btn-full { width: 100%; }
.btn-sm { padding: 5px 10px; font-size: 11px; }

/* ── MAIN ── */
.main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

/* TOP BAR */
.topbar {
  padding: 10px 20px;
  border-bottom: 1px solid var(--border);
  background: var(--surf);
  display: flex; align-items: center; justify-content: space-between;
  flex-shrink: 0; gap: 10px;
}
.topbar-left { display: flex; align-items: center; gap: 10px; }
.tab-breadcrumb { font-size: 13px; font-weight: 600; color: var(--text); }
.topbar-right { display: flex; align-items: center; gap: 8px; }
.chip {
  background: var(--surf2); border: 1px solid var(--border2);
  border-radius: 5px; padding: 5px 12px;
  font-family: var(--mono); font-size: 12px; color: var(--gold);
}
.chip .label { color: var(--sub); font-size: 10px; margin-right: 4px; }

/* CONTENT */
.content { flex: 1; overflow-y: auto; padding: 18px 20px; }

/* PROJECT INFO */
.proj-card {
  background: var(--surf); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 14px 16px; margin-bottom: 16px;
}
.proj-card-title {
  font-size: 10px; font-weight: 700; color: var(--sub);
  letter-spacing: .1em; text-transform: uppercase; margin-bottom: 10px;
}
.proj-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; }
.proj-field label { display: block; font-size: 10px; color: var(--sub); margin-bottom: 4px; }
.proj-field input {
  width: 100%; background: var(--surf2); border: 1px solid var(--border2);
  border-radius: 4px; color: var(--text); font-family: var(--sans);
  font-size: 12px; padding: 5px 8px; outline: none;
  transition: border-color .15s;
}
.proj-field input:focus { border-color: var(--blue); }

/* PANELS */
.panel { display: none; }
.panel.active { display: block; }

/* WORK TABLE */
.wtable-card {
  background: var(--surf); border: 1px solid var(--border);
  border-radius: var(--radius); overflow: hidden; margin-bottom: 14px;
}
.wtable-head {
  padding: 10px 14px 9px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
}
.wtable-head-left h3 { font-size: 13px; font-weight: 700; }
.wtable-head-left p  { font-size: 10px; color: var(--sub); margin-top: 1px; }
.wtable-head-right { display: flex; gap: 6px; align-items: center; }

table { width: 100%; border-collapse: collapse; }
thead th {
  background: var(--surf2); padding: 6px 8px;
  font-size: 10px; color: var(--sub); font-weight: 700;
  letter-spacing: .06em; text-align: left;
  border-bottom: 1px solid var(--border); white-space: nowrap;
}
td { padding: 4px 6px; border-bottom: 1px solid #18222e; vertical-align: middle; }
tbody tr:last-child td { border-bottom: none; }
tbody tr:hover td { background: #151f2e; }

/* CELL INPUTS */
.ci {
  width: 100%; background: transparent; border: 1px solid transparent;
  border-radius: 3px; color: var(--text); font-family: var(--sans);
  font-size: 12px; padding: 3px 5px; outline: none;
  transition: border-color .12s, background .12s;
}
.ci:focus { border-color: var(--blue); background: #172236; }
.ci.r { text-align: right; font-family: var(--mono); }
.ci:hover:not(:focus) { border-color: var(--border2); }

.td-r  { text-align: right; font-family: var(--mono); font-size: 11.5px; }
.td-amt{ text-align: right; font-family: var(--mono); font-size: 12px; color: var(--gold); font-weight: 600; }
.td-n  { text-align: center; color: var(--sub); font-size: 10px; font-family: var(--mono); }

.row-del {
  background: none; border: none; color: #3a2020;
  cursor: pointer; padding: 2px 5px; border-radius: 3px;
  font-size: 13px; transition: color .12s, background .12s;
}
.row-del:hover { color: var(--red); background: #2a1010; }

/* FOOTER ROW */
tfoot tr td {
  background: var(--surf2); border-top: 1.5px solid var(--border2);
  padding: 7px 8px; font-weight: 700; font-size: 12px;
}
.tfoot-label { font-family: var(--sans); color: var(--sub); font-size: 11px; }
.tfoot-total { text-align: right; font-family: var(--mono); color: var(--gold); }

/* SUMMARY */
.sum-grid { display: grid; grid-template-columns: 1fr 360px; gap: 14px; margin-bottom: 14px; }
.sum-card {
  background: var(--surf); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 14px;
}
.sum-card-title {
  font-size: 10px; font-weight: 700; color: var(--sub);
  letter-spacing: .1em; text-transform: uppercase; margin-bottom: 10px;
}
.sum-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 6px 0; border-bottom: 1px solid var(--border); gap: 8px;
}
.sum-row:last-child { border-bottom: none; }
.sum-row .sn { font-size: 12px; color: var(--text); flex: 1; }
.sum-row .sv { font-family: var(--mono); font-size: 12px; color: var(--gold); font-weight: 600; white-space: nowrap; }
.sum-row .sp { font-size: 10px; color: var(--sub); width: 36px; text-align: right; }
.pct-bar { height: 3px; background: var(--border); border-radius: 2px; margin-top: 2px; }
.pct-fill { height: 100%; border-radius: 2px; background: var(--gold); transition: width .4s; }

.grand-box {
  background: linear-gradient(135deg, #142214, #1a321a);
  border: 1px solid #2d5c2d; border-radius: var(--radius);
  padding: 16px 20px; display: flex; align-items: center;
  justify-content: space-between; margin-bottom: 14px;
}
.grand-box .gl { }
.grand-box .gl-title { font-size: 14px; font-weight: 600; color: var(--text); }
.grand-box .gl-sub   { font-size: 10px; color: var(--sub); margin-top: 3px; }
.grand-box .gl-amt   { font-size: 28px; font-weight: 700; color: var(--green); font-family: var(--mono); }

/* TOAST */
.toast {
  position: fixed; bottom: 20px; right: 20px;
  padding: 10px 18px; border-radius: var(--radius);
  font-size: 13px; font-weight: 600; z-index: 9999;
  box-shadow: 0 4px 16px rgba(0,0,0,.4);
  transition: opacity .3s; opacity: 1;
}

/* MODAL OVERLAY */
.overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,.7); z-index: 1000;
  align-items: center; justify-content: center;
}
.overlay.show { display: flex; }
.modal {
  background: var(--surf); border: 1px solid var(--border2);
  border-radius: 8px; padding: 24px; width: 440px; max-width: 95vw;
}
.modal h3 { font-size: 15px; margin-bottom: 6px; }
.modal p  { font-size: 12px; color: var(--sub); margin-bottom: 16px; line-height: 1.6; }
.modal-actions { display: flex; gap: 8px; justify-content: flex-end; }

/* ADD SECTION MODAL */
.overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.75); z-index:1000; align-items:center; justify-content:center; }
.overlay.show { display:flex; }
.modal { background:var(--surf); border:1px solid var(--border2); border-radius:8px; padding:22px 24px; width:420px; max-width:95vw; }
.modal h3 { font-size:15px; font-weight:700; margin-bottom:6px; }
.modal p  { font-size:12px; color:var(--sub); margin-bottom:14px; line-height:1.6; }
.modal-row { display:flex; gap:8px; margin-bottom:10px; align-items:center; }
.modal-row label { font-size:11px; color:var(--sub); width:60px; flex-shrink:0; }
.modal-row input { flex:1; background:var(--surf2); border:1px solid var(--border2); border-radius:4px; color:var(--text); font-family:var(--sans); font-size:13px; padding:6px 9px; outline:none; }
.modal-row input:focus { border-color:var(--blue); }
.modal-actions { display:flex; gap:8px; justify-content:flex-end; margin-top:16px; }
.emoji-grid { display:flex; flex-wrap:wrap; gap:6px; margin-top:4px; }
.emoji-opt { font-size:18px; cursor:pointer; padding:4px 6px; border-radius:4px; border:2px solid transparent; transition:.12s; }
.emoji-opt:hover { background:var(--surf2); }
.emoji-opt.sel { border-color:var(--gold); background:var(--surf2); }

/* NAV SECTION DEL BTN */
.nav-sec-del { display:none; margin-left:auto; background:none; border:none; color:#3a2020; cursor:pointer; font-size:11px; padding:2px 4px; border-radius:3px; flex-shrink:0; }
.nav-item:hover .nav-sec-del { display:inline-block; }
.nav-sec-del:hover { color:var(--red); background:#2a1010; }
.nav-item.active .nav-sec-del { display:inline-block; color:var(--gold-dim); }

/* ADD SECTION BTN in sidebar */
.btn-add-sec { display:flex; align-items:center; gap:7px; padding:7px 16px; cursor:pointer; color:var(--blue); font-size:12px; border:none; background:none; width:100%; font-family:var(--sans); border-left:3px solid transparent; transition:.12s; }
.btn-add-sec:hover { background:var(--surf2); }

/* PRINT */
@media print {
  :root { --bg:#fff; --surf:#fff; --surf2:#f5f5f5; --border:#ddd; --border2:#ccc;
          --text:#000; --sub:#555; --gold:#b8860b; --green:#1b5e20; }
  .sidebar, .topbar, .sb-footer, .row-del, .btn-add, .wtable-head-right { display: none !important; }
  .app { display: block; }
  .main { overflow: visible; }
  .content { overflow: visible; padding: 0; }
  .panel { display: block !important; }
  .proj-grid { grid-template-columns: repeat(3,1fr); }
  .sum-grid  { grid-template-columns: 1fr; }
  canvas     { display: none; }
  .wtable-card { page-break-inside: avoid; }
  .ph { display: block !important; text-align: center; padding: 12pt 0 10pt; margin-bottom: 14pt; border-bottom: 2pt solid #000; }
  .ph h2 { font-size: 16pt; }
  .ph p  { font-size: 11pt; color: #333; }
  .ci { background: transparent !important; border: none !important; }
}
.ph { display: none; }
</style>
</head>
<body>
<div class="app">

<!-- ── SIDEBAR ── -->
<div class="sidebar">
  <div class="sb-logo">
    <div class="title">ถอดแบบ &amp; ประมาณราคา</div>
    <div class="sub">งานโครงสร้างอาคาร</div>
  </div>

  <div class="nav-block">
    <div class="nav-cat">ภาพรวม</div>
    <div class="nav-item active" onclick="show('summary')" id="nav-summary">
      <span class="ico">📊</span>สรุปรวมทุกหมวด
      <span class="nav-subtotal" id="ns-summary"></span>
    </div>
  </div>

  <div class="nav-block">
    <div class="nav-cat">หมวดงาน</div>
    <div id="navSections"></div>
    <button class="btn-add-sec" onclick="openAddSection()">
      <span style="font-size:16px;line-height:1">＋</span> เพิ่มหมวดงาน
    </button>
  </div>

  <div class="sb-footer">
    <button class="btn btn-gold btn-full" onclick="doPrint()">🖨 พิมพ์ / Export PDF</button>
    <button class="btn btn-green btn-full" onclick="exportJSON()">💾 บันทึก (.json)</button>
    <button class="btn btn-ghost btn-full" onclick="triggerImport()">📂 โหลดไฟล์ (.json)</button>
    <input type="file" id="fileInput" accept=".json" style="display:none" onchange="importJSON(this)">
  </div>
</div>

<!-- ── MAIN ── -->
<div class="main">
  <!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-left">
      <span class="tab-breadcrumb" id="breadcrumb">สรุปรวมทุกหมวด</span>
    </div>
    <div class="topbar-right">
      <div class="chip"><span class="label">รวมทั้งหมด</span><span id="chipTotal">฿ 0.00</span></div>
      <button class="btn btn-ghost btn-sm" onclick="exportJSON()">💾 บันทึก</button>
      <button class="btn btn-ghost btn-sm" onclick="doPrint()">🖨 พิมพ์</button>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="content">

    <!-- PRINT HEADER -->
    <div class="ph">
      <h2>ใบถอดแบบและประมาณราคางานโครงสร้าง</h2>
      <p id="phInfo"></p>
    </div>

    <!-- PROJECT INFO -->
    <div class="proj-card" id="projCard">
      <div class="proj-card-title">ข้อมูลโครงการ</div>
      <div class="proj-grid">
        <div class="proj-field"><label>ชื่อโครงการ</label><input id="pName" placeholder="อาคารเอนกประสงค์..."></div>
        <div class="proj-field"><label>สถานที่ก่อสร้าง</label><input id="pLoc" placeholder="อ.บ้านแพ้ว จ.สมุทรสาคร"></div>
        <div class="proj-field"><label>วันที่ประมาณ</label><input id="pDate" type="date"></div>
        <div class="proj-field"><label>ผู้ถอดแบบ</label><input id="pBy" placeholder="ชื่อ-นามสกุล"></div>
        <div class="proj-field"><label>เจ้าของโครงการ</label><input id="pOwner" placeholder="ชื่อเจ้าของ / หน่วยงาน"></div>
        <div class="proj-field"><label>หมายเหตุ</label><input id="pNote" placeholder="..."></div>
      </div>
    </div>

    <!-- SUMMARY PANEL -->
    <div class="panel active" id="panel-summary">
      <div class="sum-grid">
        <div class="sum-card">
          <div class="sum-card-title">สรุปแยกหมวดงาน</div>
          <div id="sumRows"></div>
        </div>
        <div class="sum-card">
          <div class="sum-card-title">สัดส่วนค่าใช้จ่าย</div>
          <canvas id="pieChart" width="320" height="200"></canvas>
          <div id="pieLegend" style="margin-top:10px;font-size:10px;display:flex;flex-wrap:wrap;gap:6px"></div>
        </div>
      </div>
      <div class="grand-box">
        <div class="gl">
          <div class="gl-title">ราคารวมงานโครงสร้างทั้งหมด</div>
          <div class="gl-sub">ยังไม่รวม VAT 7% และค่าดำเนินการ</div>
        </div>
        <div class="gl-amt" id="grandBig">฿ 0.00</div>
      </div>
      <div class="sum-card">
        <div class="sum-card-title">เงื่อนไขและหมายเหตุ</div>
        <textarea id="sumNote" style="width:100%;background:transparent;border:none;color:var(--text);font-family:var(--sans);font-size:12px;resize:vertical;outline:none;min-height:54px;margin-top:6px" placeholder="ราคานี้เป็นการประมาณเบื้องต้น อาจมีการเปลี่ยนแปลงตามสภาพจริงหน้างาน..."></textarea>
      </div>
    </div>

    <!-- WORK PANELS (t01–t14) -->
    <div id="workPanels"></div>

  </div>
</div>
</div>

<!-- ADD/EDIT SECTION MODAL -->
<div class="overlay" id="secModal">
  <div class="modal">
    <h3 id="secModalTitle">➕ เพิ่มหมวดงานใหม่</h3>
    <p>กำหนดชื่อและไอคอนสำหรับหมวดงาน</p>
    <div class="modal-row">
      <label>ชื่อหมวด</label>
      <input id="secName" placeholder="เช่น งานระบบประปา, งานไฟฟ้า..." maxlength="40">
    </div>
    <div class="modal-row" style="align-items:flex-start">
      <label style="padding-top:4px">ไอคอน</label>
      <div>
        <div class="emoji-grid" id="emojiGrid"></div>
        <input id="secIcon" placeholder="หรือพิมพ์ emoji เอง เช่น 🔧" maxlength="4"
          style="margin-top:8px;width:140px" oninput="selectEmoji(this.value)">
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeSecModal()">ยกเลิก</button>
      <button class="btn btn-green" id="secModalOk" onclick="confirmSection()">✅ เพิ่มหมวด</button>
    </div>
  </div>
</div>

<!-- CONFIRM DELETE MODAL -->
<div class="overlay" id="confirmModal">
  <div class="modal">
    <h3 id="modalTitle">ยืนยัน</h3>
    <p id="modalMsg"></p>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal()">ยกเลิก</button>
      <button class="btn btn-danger" id="modalOk">ยืนยัน</button>
    </div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════
// DATA
// ═══════════════════════════════════════════════════════
var SECS = [
  { id:'t01', name:'งานดิน / คอนกรีตรองพื้น', icon:'🪨', rows:[
    {d:'ขุดดินตอม่อ 0.80×0.80×1.20 ม.',u:'m³',q:12,p:250,r:''},
    {d:'ถมดินบดอัดแน่น',u:'m³',q:8,p:180,r:''},
    {d:"คอนกรีตหยาบรองพื้น t=5cm f'c=100ksc",u:'m²',q:45,p:220,r:''},
  ]},
  { id:'t02', name:'เสาเข็ม / ตอม่อ', icon:'🔩', rows:[
    {d:'เสาเข็มสปัน Φ0.30 ม. ยาว 12 ม.',u:'ต้น',q:20,p:4500,r:''},
    {d:'ตัดหัวเสาเข็ม',u:'ต้น',q:20,p:350,r:''},
    {d:'Short Pier คสล. 0.30×0.30×1.00 ม.',u:'ต้น',q:20,p:1800,r:''},
  ]},
