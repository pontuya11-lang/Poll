function renderTable(sec){
  var wrap=document.getElementById('tbl-'+sec.id); if(!wrap) return;
  var h='<div class="wtable-card"><div class="wtable-head">';
  h+='<div class="wtable-head-left"><h3>'+sec.icon+' '+sec.name+'</h3>';
  h+='<p>คลิกเซลล์เพื่อแก้ไข — คำนวณอัตโนมัติ</p></div>';
  h+='<div class="wtable-head-right">';
  h+='<button class="btn btn-ghost btn-sm" onclick="openEditSection(\''+sec.id+'\')">✏️ แก้ชื่อ</button>';
  h+='<button class="btn btn-blue btn-sm btn-add" onclick="addRow(\''+sec.id+'\')">+ เพิ่มรายการ</button>';
  h+='<button class="btn btn-danger btn-sm" onclick="promptDelSection(\''+sec.id+'\')">🗑 ลบหมวด</button>';
  h+='</div></div>';
  h+='<table><thead><tr>';
  h+='<th style="width:34px">#</th><th>รายการ</th><th style="width:68px">หน่วย</th>';
  h+='<th style="width:88px">ปริมาณ</th><th style="width:116px">ราคา/หน่วย (฿)</th>';
  h+='<th style="width:120px">รวมเงิน (฿)</th><th style="width:110px">หมายเหตุ</th>';
  h+='<th style="width:34px"></th></tr></thead><tbody>';
  sec.rows.forEach(function(row,i){h+=rowHTML(sec.id,i,row);});
  h+='</tbody><tfoot><tr>';
  h+='<td colspan="5" class="tfoot-label">รวม '+sec.name+'</td>';
  h+='<td class="tfoot-total" id="ft-'+sec.id+'">'+fmt(secTotal(sec))+'</td>';
  h+='<td></td><td></td></tr></tfoot></table></div>';
  wrap.innerHTML=h;
}

function rowHTML(sid,i,row){
  var dv=e(row.d||''),uv=e(row.u||''),rv=e(row.r||'');
  return '<tr>'
    +'<td class="td-n">'+(i+1)+'</td>'
    +'<td><input class="ci" value="'+dv+'" oninput="setField(\''+sid+'\','+i+',\'d\',this.value)"></td>'
    +'<td><input class="ci" value="'+uv+'" oninput="setField(\''+sid+'\','+i+',\'u\',this.value)" style="text-align:center"></td>'
    +'<td><input class="ci r" type="number" value="'+row.q+'" oninput="setNum(\''+sid+'\','+i+',\'q\',this)"></td>'
    +'<td><input class="ci r" type="number" value="'+row.p+'" oninput="setNum(\''+sid+'\','+i+',\'p\',this)"></td>'
    +'<td class="td-amt" id="ca-'+sid+'-'+i+'">'+fmt(row.q*row.p)+'</td>'
    +'<td><input class="ci" value="'+rv+'" oninput="setField(\''+sid+'\','+i+',\'r\',this.value)" placeholder="—"></td>'
    +'<td><button class="row-del" onclick="delRow(\''+sid+'\','+i+')" title="ลบแถว">✕</button></td>'
    +'</tr>';
}

function e(s){return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;');}
function getSec(sid){return SECS.find(function(s){return s.id===sid;});}
function setField(sid,i,key,val){var s=getSec(sid);if(s&&s.rows[i])s.rows[i][key]=val;}
function setNum(sid,i,key,inp){
  var s=getSec(sid);if(!s||!s.rows[i])return;
  s.rows[i][key]=parseFloat(inp.value)||0; recalcRow(sid,i);
}
function recalcRow(sid,i){
  var s=getSec(sid);if(!s||!s.rows[i])return;
  var r=s.rows[i];
  var c=document.getElementById('ca-'+sid+'-'+i); if(c)c.textContent=fmt(r.q*r.p);
  var f=document.getElementById('ft-'+sid); if(f)f.textContent=fmt(secTotal(s));
  updateNS(sid); updateChip();
}
function addRow(sid){var s=getSec(sid);if(!s)return;s.rows.push({d:'รายการใหม่',u:'ครั้ง',q:1,p:0,r:''});renderTable(s);updateNS(sid);updateChip();}
function delRow(sid,i){var s=getSec(sid);if(!s)return;s.rows.splice(i,1);renderTable(s);updateNS(sid);updateChip();}
function secTotal(s){return s.rows.reduce(function(t,r){return t+(+r.q||0)*(+r.p||0);},0);}
function grandTotal(){return SECS.reduce(function(t,s){return t+secTotal(s);},0);}
function fmt(n){return(n||0).toLocaleString('th-TH',{minimumFractionDigits:2,maximumFractionDigits:2});}
function shortFmt(n){if(n>=1e6)return '฿'+(n/1e6).toFixed(1)+'M';if(n>=1e3)return '฿'+(n/1e3).toFixed(0)+'K';return '฿'+fmt(n);}
function updateNS(sid){var el=document.getElementById('ns-'+sid);if(!el)return;var s=getSec(sid);if(!s)return;el.textContent=secTotal(s)>0?shortFmt(secTotal(s)):'';}
function updateChip(){var t=grandTotal();document.getElementById('chipTotal').textContent='฿ '+fmt(t);SECS.forEach(function(s){updateNS(s.id);});}

// ── SUMMARY + PIE ─────────────────────────────────────
function renderSummary(){
  var total=grandTotal(),rows=document.getElementById('sumRows');
  rows.innerHTML='';
  SECS.forEach(function(s,i){
    var t=secTotal(s),pct=total>0?(t/total*100):0;
    rows.innerHTML+='<div class="sum-row"><div style="flex:1">'
      +'<div style="display:flex;justify-content:space-between">'
      +'<span class="sn">'+s.icon+' '+s.name+'</span><span class="sv">฿ '+fmt(t)+'</span></div>'
      +'<div class="pct-bar"><div class="pct-fill" style="width:'+pct.toFixed(1)+'%;background:'+COLORS[i%COLORS.length]+'"></div></div>'
      +'</div><span class="sp">'+pct.toFixed(1)+'%</span></div>';
  });
  document.getElementById('grandBig').textContent='฿ '+fmt(total);
  updateChip(); drawPie(total);
}

function drawPie(total){
  var canvas=document.getElementById('pieChart'),legend=document.getElementById('pieLegend');
  if(!canvas)return;
  var ctx=canvas.getContext('2d'),W=canvas.width,H=canvas.height;
  ctx.clearRect(0,0,W,H);
  var cx=W*0.4,cy=H*0.5,r=Math.min(cx,cy)-14,start=-Math.PI/2;
  legend.innerHTML='';
  SECS.forEach(function(s,i){
    var t=secTotal(s);if(t<=0)return;
    var angle=(t/total)*Math.PI*2,color=COLORS[i%COLORS.length];
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,start,start+angle);ctx.closePath();
    ctx.fillStyle=color;ctx.fill();ctx.strokeStyle='#0b0f18';ctx.lineWidth=2;ctx.stroke();
    if(angle>0.25){
      var mid=start+angle/2;
      ctx.fillStyle='#0b0f18';ctx.font='bold 10px monospace';ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText((t/total*100).toFixed(0)+'%',cx+Math.cos(mid)*r*.65,cy+Math.sin(mid)*r*.65);
    }
    start+=angle;
    legend.innerHTML+='<div style="display:flex;align-items:center;gap:4px">'
      +'<div style="width:9px;height:9px;border-radius:2px;background:'+color+';flex-shrink:0"></div>'
      +'<span style="color:var(--sub);font-size:9px">'+s.name.substring(0,10)+'</span></div>';
  });
}

// ── EXPORT / IMPORT ───────────────────────────────────
function getState(){
  return{version:3,
    project:{name:document.getElementById('pName').value,loc:document.getElementById('pLoc').value,
      date:document.getElementById('pDate').value,by:document.getElementById('pBy').value,
      owner:document.getElementById('pOwner').value,note:document.getElementById('pNote').value},
    note:document.getElementById('sumNote').value,
    sections:SECS.map(function(s){return{id:s.id,name:s.name,icon:s.icon,rows:s.rows.map(function(r){return Object.assign({},r);})};})
  };
}

function exportJSON(){
  var st=getState(),pname=st.project.name||'project',date=st.project.date||new Date().toISOString().split('T')[0];
  var fn='ถอดแบบ_'+pname+'_'+date+'.json';
  var blob=new Blob([JSON.stringify(st,null,2)],{type:'application/json'});
  var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=fn;a.click();URL.revokeObjectURL(a.href);
  toast('บันทึก '+fn+' ✓','var(--green)');
}

function triggerImport(){document.getElementById('fileInput').click();}

function importJSON(input){
  var file=input.files[0];if(!file)return;
  var reader=new FileReader();
  reader.onload=function(e){
    try{
      var st=JSON.parse(e.target.result); applyState(st);
      toast('โหลด '+(st.project&&st.project.name||file.name)+' ✓','var(--blue)');
    }catch(err){toast('ไฟล์ไม่ถูกต้อง: '+err.message,'var(--red)');}
  };
  reader.readAsText(file,'utf-8'); input.value='';
}

function applyState(st){
  if(st.project){
    var p=st.project;
    ['name','loc','date','by','owner','note'].forEach(function(k){
      var el=document.getElementById('p'+k.charAt(0).toUpperCase()+k.slice(1));if(el)el.value=p[k]||'';
    });
  }
  if(st.note){var sn=document.getElementById('sumNote');if(sn)sn.value=st.note;}
  if(st.sections){
    SECS.length=0;
    st.sections.forEach(function(s){
      SECS.push({id:s.id,name:s.name||s.id,icon:s.icon||'📋',
        rows:(s.rows||[]).map(function(r){return{d:r.d||'',u:r.u||'',q:+r.q||0,p:+r.p||0,r:r.r||''};})});
    });
    SECS.forEach(function(s){var n=parseInt(s.id.replace(/\D/g,''));if(n>_secIdCounter)_secIdCounter=n;});
    buildWorkPanels(); renderNav();
  }
  updateChip(); if(currentTab==='summary') renderSummary();
}

