// ── NAV ──────────────────────────────────────────────
function renderNav(){
  var wrap=document.getElementById('navSections'); if(!wrap) return;
  wrap.innerHTML='';
  SECS.forEach(function(s){
    var div=document.createElement('div');
    div.className='nav-item'+(currentTab===s.id?' active':'');
    div.id='nav-'+s.id;
    div.innerHTML='<span class="ico">'+s.icon+'</span>'
      +'<span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+s.name+'</span>'
      +'<span class="nav-subtotal" id="ns-'+s.id+'"></span>'
      +'<button class="nav-sec-del" onclick="event.stopPropagation();promptDelSection(\''+s.id+'\')" title="ลบหมวด">✕</button>';
    div.onclick=function(){ show(s.id); };
    wrap.appendChild(div);
  });
}

function show(id){
  document.querySelectorAll('.panel').forEach(function(p){p.classList.remove('active');});
  document.querySelectorAll('.nav-item').forEach(function(n){n.classList.remove('active');});
  var panel=document.getElementById('panel-'+id);
  if(panel) panel.classList.add('active');
  var nav=document.getElementById('nav-'+id);
  if(nav) nav.classList.add('active');
  var sec=getSec(id);
  document.getElementById('breadcrumb').textContent=id==='summary'?'สรุปรวมทุกหมวด':(sec?sec.name:id);
  currentTab=id;
  if(id==='summary') renderSummary();
}

