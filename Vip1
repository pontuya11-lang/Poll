function openAddSection(){
  _editSecId=null; _selectedEmoji='📋';
  document.getElementById('secModalTitle').textContent='➕ เพิ่มหมวดงานใหม่';
  document.getElementById('secModalOk').textContent='✅ เพิ่มหมวด';
