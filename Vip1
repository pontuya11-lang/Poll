  document.getElementById('secModal').classList.add('show');
  setTimeout(function(){document.getElementById('secName').focus();},100);
}

function openEditSection(sid){
  var sec=getSec(sid); if(!sec) return;
  _editSecId=sid; _selectedEmoji=sec.icon;
  document.getElementById('secModalTitle').textContent='✏️ แก้ชื่อหมวดงาน';
  document.getElementById('secModalOk').textContent='✅ บันทึก';
  document.getElementById('secName').value=sec.name;
  document.getElementById('secIcon').value=sec.icon;
  buildEmojiGrid();
  document.getElementById('secModal').classList.add('show');
  setTimeout(function(){document.getElementById('secName').focus();},100);
}

function buildEmojiGrid(){
  var grid=document.getElementById('emojiGrid'); grid.innerHTML='';
  EMOJIS.forEach(function(em){
    var span=document.createElement('span');
    span.className='emoji-opt'+(em===_selectedEmoji?' sel':'');
    span.textContent=em;
    span.onclick=function(){selectEmoji(em);};
    grid.appendChild(span);
  });
}

function selectEmoji(em){
  if(!em) return; _selectedEmoji=em;
  document.getElementById('secIcon').value=em;
  document.querySelectorAll('.emoji-opt').forEach(function(el){
    el.classList.toggle('sel',el.textContent===em);
  });
}

function closeSecModal(){
  document.getElementById('secModal').classList.remove('show'); _editSecId=null;
}

function confirmSection(){
  var name=document.getElementById('secName').value.trim();
  if(!name){document.getElementById('secName').focus();return;}
  var icon=_selectedEmoji||document.getElementById('secIcon').value||'📋';
  if(_editSecId){
    var sec=getSec(_editSecId);
    if(sec){sec.name=name; sec.icon=icon;}
    renderNav(); renderTable(getSec(_editSecId)); show(_editSecId);
    toast('แก้ไขหมวด "'+name+'" เรียบร้อย ✓','var(--blue)');
  } else {
    _secIdCounter++;
    var newId='c'+_secIdCounter;
    SECS.push({id:newId,name:name,icon:icon,rows:[{d:'รายการที่ 1',u:'ครั้ง',q:1,p:0,r:''}]});
    var wrap=document.getElementById('workPanels');
    var div=document.createElement('div');
    div.className='panel'; div.id='panel-'+newId;
    div.innerHTML='<div id="tbl-'+newId+'"></div>';
    wrap.appendChild(div);
    renderTable(getSec(newId)); renderNav(); show(newId);
    toast('เพิ่มหมวด "'+name+'" เรียบร้อย ✓','var(--green)');
  }
  updateChip(); closeSecModal();
}

function promptDelSection(sid){
  var sec=getSec(sid); if(!sec) return;
  confirm2('🗑 ลบหมวด "'+sec.name+'"',
    'รายการทั้งหมด '+sec.rows.length+' รายการจะหายไป ยืนยันลบ?',
    function(){deleteSection(sid);});
}

function deleteSection(sid){
  var idx=SECS.findIndex(function(s){return s.id===sid;}); if(idx<0) return;
  var name=SECS[idx].name; SECS.splice(idx,1);
  var p=document.getElementById('panel-'+sid); if(p) p.remove();
  renderNav(); updateChip();
  if(currentTab===sid) show('summary');
  toast('ลบหมวด "'+name+'" เรียบร้อย','var(--red)');
}

// ── TABLES ───────────────────────────────────────────
function buildWorkPanels(){
