function doPrint(){
  var p=getState().project;
  document.getElementById('phInfo').textContent=[p.name,p.loc,'วันที่: '+p.date,'ผู้ถอดแบบ: '+p.by].filter(Boolean).join(' | ');
  window.print();
}

